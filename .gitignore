__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Packaging artefacts — generated by `python -m build`, uploaded to PyPI separately
dist/
build/
*.egg-info/

# Local config — never commit credentials
.pypirc
.env
.env.local

# Local persisted state — the MCP server writes here at runtime
.basketwatch-mcp/
